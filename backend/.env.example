# LLM — see agents/llm.py for dispatch, config.py for validation.
# LLM_PROVIDER selects the wire protocol init_chat_model() uses. Allowed values:
#   openai        -> any OpenAI-wire-compatible gateway: OpenRouter, Together, Groq, vLLM, ...
#                    point LLM_BASE_URL at the gateway.
#   anthropic     -> native Anthropic Messages API (bypasses any gateway; ignores LLM_BASE_URL).
#   google_genai  -> native Google Gemini API (bypasses any gateway; ignores LLM_BASE_URL).
# Native providers (anthropic/google_genai) need the `providers` extra — already included in
# `.[dev]` (see pyproject.toml); for a prod install without dev tools: pip install '.[providers]'
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
# Optional, only meaningful for OpenRouter (app-ranking dashboard headers):
LLM_SITE_URL=
LLM_APP_NAME=

# Model id, per provider:
#   openai + OpenRouter -> "anthropic/claude-sonnet-5", "openai/gpt-4o", "google/gemini-2.5-pro"
#   anthropic (native)  -> "claude-sonnet-5"
#   google_genai        -> "gemini-2.5-pro"
RESEARCH_MODEL=anthropic/claude-sonnet-5

# Search tools
EXA_API_KEY=
TAVILY_API_KEY=
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=agentdrops-market-research/0.1

# Infra — matches docker-compose.yml defaults; `docker compose up -d` to start all three
DATABASE_URL=postgresql+asyncpg://agentdrops:agentdrops@localhost:5432/agentdrops
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

LOG_LEVEL=INFO

# Observability — SigNoz (deployed from ../casting.yaml via `foundryctl cast`).
# UI at http://localhost:8080; OTLP gRPC 4317, OTLP HTTP 4318, MCP server 8000.
# Set OTEL_ENABLED=false to run without a collector (no exporter retries in the logs).
OTEL_ENABLED=true
OTEL_SERVICE_NAME=agentdrops-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_ENVIRONMENT=development
